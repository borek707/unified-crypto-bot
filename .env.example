# Hyperliquid Exchange API
HYPERLIQUID_API_KEY=your_api_key_here
HYPERLIQUID_SECRET=your_secret_here

# Optional: Alternative exchanges (for fallback)
# BINANCE_API_KEY=
# BINANCE_SECRET=

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# EMAIL_ALERT_TO=admin@example.com

# Environment
ENV=production  # or development, staging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# Risk Settings (override config)
# MAX_DAILY_LOSS_PCT=5.0
# EMERGENCY_STOP_ENABLED=true